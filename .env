# ── Model ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── Inference ─────────────────────────────────────────────────────────────────
# 8GB VRAM-friendly defaults
NUM_CTX=8192
NUM_PREDICT=512
NUM_THREAD=8
REPEAT_PENALTY=1.05
TOP_K_THINKING=40
TOP_P_THINKING=0.90
TEMPERATURE_THINKING=0.35
TOP_K_FAST=30
TOP_P_FAST=0.85
TEMPERATURE_FAST=0.50
OLLAMA_KEEP_ALIVE=10m

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_SIZE=6
STORAGE_DIR=./storage
COMPACT_AT_TOKENS=6000
AUTO_COMPACT=1

# ── Ollama server performance knobs ───────────────────────────────────────────
# These must be set in the environment that starts Ollama itself.
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0